import gradio as gr
from ultralytics import YOLO
from google.colab import drive
import cv2
import numpy as np

# Connect Google Drive
drive.mount('/content/drive')

# Load trained model
model = YOLO("/content/drive/MyDrive/helmet_mmodel_v2.pt")

def detect_helmet(image):

    results = model(image, conf=0.20)[0]
    annotated = results.plot()

    boxes = results.boxes
    names = results.names

    status = "⚠ Helmet Status Unclear"

    if boxes is not None and len(boxes) > 0:

        classes = boxes.cls.tolist()
        detected = [names[int(i)] for i in classes]

        if "with helmet" in detected or "helmet" in detected:
            status = "✅ Helmet Detected"

        elif "without helmet" in detected or "no-helmet" in detected:
            status = "❌ No Helmet Detected"

    return annotated, status


demo = gr.Interface(
    fn=detect_helmet,
    inputs=gr.Image(type="numpy", sources=["upload","webcam"], label="Upload Image or Use Webcam"),
    outputs=[
        gr.Image(label="Detection Result"),
        gr.Textbox(label="Helmet Status")
    ],
    title="🚦 AI Helmet Detection System",
    description="Upload an image or capture from webcam to detect helmet usage.",
    theme="soft"
)

demo.launch()
